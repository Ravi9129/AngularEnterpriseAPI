{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "ConnectionStrings": {
        "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=AngularEnterpriseDb;Trusted_Connection=True;MultipleActiveResultSets=true"
    },
    "JwtSettings": {
        "Secret": "YourSuperSecretKeyHereAtLeast32CharactersLong!",
        "Issuer": "AngularEnterpriseAPI",
        "Audience": "AngularEnterpriseApp",
