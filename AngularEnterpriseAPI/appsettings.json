    "CorsSettings": {
        "AllowedOrigins": [
            "http://localhost:4200",
            "https://localhost:4200"
        ]
    },
    "ApiSettings": {
        "ApiVersion": "v1",
        "ApiTitle": "Angular Enterprise API",
        "ApiDescription": "Backend API for Angular Enterprise Application"
    },
    "AllowedHosts": "*"
}